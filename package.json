    "framer-motion": "^11.11.0",
    "gsap": "^3.12.5",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.453.0",
    "next": "14.2.15",
    "next-auth": "^4.24.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-leaflet": "^4.2.1",
    "sharp": "^0.33.5",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.5.4",
